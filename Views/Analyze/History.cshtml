@model List<AnalyzedMessage>
@{
    ViewData["Title"] = "السجل";
}

<div class="max-w-6xl mx-auto space-y-6 animate-fade-in">
    
    <!-- رأس الصفحة مع الأيقونة والوصف -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-extrabold text-white tracking-tight flex items-center gap-2">
                <i class="bi bi-clock-history text-blue-500"></i> سجل العمليات المرصودة
            </h1>
            <p class="text-sm text-gray-400 mt-1">استعرض وتتبع كافة الرسائل ونسب الخطورة التي تم تحليلها مسبقاً.</p>
        </div>
        <div class="text-xs bg-[#1f2937]/50 text-gray-400 px-3 py-1.5 rounded-full border border-gray-800">
            إجمالي المحفوظ: @Model.Count
        </div>
    </div>

    <!-- صندوق السجل والجدول الاحترافي -->
    <div class="bg-[#1f2937]/30 border border-gray-800 rounded-2xl p-6 shadow-2xl backdrop-blur-sm">
        @if (!Model.Any())
        {
            <div class="text-center py-12 text-gray-500 text-sm flex flex-col items-center gap-3">
                <div class="w-16 h-16 rounded-full bg-gray-800/50 flex items-center justify-center text-gray-600 border border-gray-800">
                    <i class="bi bi-folder-x text-3xl"></i>
                </div>
                <span class="font-medium">السجل فارغ تماماً. لم يتم فحص أي رسائل بعد.</span>
            </div>
        }
        else
        {
            <div class="overflow-x-auto text-sm text-gray-300">
                <table class="w-full text-right border-collapse">
                    <thead>
                        <tr class="border-b border-gray-800 text-gray-400 text-xs uppercase tracking-wider">
                            <th class="pb-3 font-semibold w-16">المعرف</th>
                            <th class="pb-3 font-semibold">نص الرسالة</th>
                            <th class="pb-3 font-semibold text-center">درجة الخطورة</th>
                            <th class="pb-3 font-semibold text-center">النتيجة</th>
                            <th class="pb-3 font-semibold text-left">التاريخ</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/40">
                        @foreach (var msg in Model)
                        {
                            // تحديد ألوان بطاقات النتائج بطريقة سيبرانية
                            string badgeStyles = msg.Result switch
                            {
                                "Scam" => "bg-red-500/10 text-red-400 border-red-500/20",
                                "Suspicious" => "bg-amber-500/10 text-amber-400 border-amber-500/20",
                                _ => "bg-green-500/10 text-green-400 border-green-500/20"
                            };

                            string resultText = msg.Result switch
                            {
                                "Scam" => "احتيال مؤكد",
                                "Suspicious" => "مشبوهة",
                                _ => "آمنة ونظيفة"
                            };

                            <tr class="hover:bg-gray-850/30 transition group">
                                <td class="py-4 text-xs font-mono text-gray-500">#@msg.MessageId</td>
                                <td class="py-4 font-medium max-w-sm truncate text-white group-hover:text-blue-400 transition-colors">
                                    @msg.Content
                                </td>
                                <td class="py-4 text-center font-mono font-bold text-sm">
                                    <span class="@(msg.RiskScore > 70 ? "text-red-400" : msg.RiskScore > 40 ? "text-amber-400" : "text-green-400")">
                                        @msg.RiskScore%
                                    </span>
                                </td>
                                <td class="py-4 text-center">
                                    <span class="border px-3 py-1 rounded-full text-xs font-bold @badgeStyles shadow-sm">
                                        @resultText
                                    </span>
                                </td>
                                <td class="py-4 text-left text-xs font-mono text-gray-500">
                                    @msg.Date.ToString("yyyy-MM-dd HH:mm")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
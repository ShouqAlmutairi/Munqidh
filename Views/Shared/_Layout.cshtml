<!-- Mounqith/Views/Shared/_Layout.cshtml -->
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - مُنقذك الحامي الذكي</title>
    
    <!-- تضمين Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- تضمين أيقونات Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- استدعاء خط القاهرة كـ Link لتجنب تعارض C# -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/site.css" />
    
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #0b111e;
            color: #f3f4f6;
        }
    </style>
</head>
<body class="flex flex-col min-h-screen">
    
    <!-- شريط التنقل العلوي الاحترافي -->
    <nav class="bg-[#111827] border-b border-gray-800 sticky top-0 z-50 shadow-lg backdrop-blur-md bg-opacity-90">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                
                <!-- شعار التطبيق الجديد (مُنقذك) -->
                <div class="flex items-center gap-3">
                    <div class="bg-blue-600 text-white p-2 rounded-xl shadow-md shadow-blue-500/30 flex items-center justify-center">
                        <i class="bi bi-shield-lock-fill text-xl"></i>
                    </div>
                    <span class="text-xl font-bold tracking-wider text-white bg-gradient-to-l from-blue-400 to-indigo-500 bg-clip-text text-transparent">مُنقذك AI</span>
                </div>
                
                <!-- القائمة البرمجية المرتبطة بالـ Controllers الخاصة بكِ -->
                <div class="flex space-x-reverse space-x-2 font-medium text-sm">
                    <a asp-controller="Home" asp-action="Index" 
                       class="text-gray-300 hover:text-blue-400 hover:bg-gray-800/50 px-3 py-2 rounded-lg transition flex items-center gap-1">
                        <i class="bi bi-house-door text-base"></i> الرئيسية
                    </a>
                    
                    <a asp-controller="Analyze" asp-action="Index" 
                       class="text-gray-300 hover:text-blue-400 hover:bg-gray-800/50 px-3 py-2 rounded-lg transition flex items-center gap-1">
                        <i class="bi bi-search text-base"></i> تحليل رسالة
                    </a>
                    
                    <a asp-controller="Analyze" asp-action="History" 
                       class="text-gray-300 hover:text-blue-400 hover:bg-gray-800/50 px-3 py-2 rounded-lg transition flex items-center gap-1">
                        <i class="bi bi-clock-history text-base"></i> السجل
                    </a>
                    
                    <a asp-controller="Dashboard" asp-action="Index" 
                       class="bg-blue-600/10 text-blue-400 border border-blue-500/20 hover:bg-blue-600 hover:text-white px-4 py-2 rounded-lg transition flex items-center gap-1 shadow-md shadow-blue-600/5">
                        <i class="bi bi-bar-chart-steps text-base"></i> لوحة التحكم
                    </a>
                </div>

            </div>
        </div>
    </nav>

    <!-- حاوية محتوى الصفحات الديناميكي -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>

    <!-- التذييل السفلي -->
    <footer class="bg-[#111827] border-t border-gray-800 py-6 text-center text-gray-500 text-xs">
        <div class="container mx-auto">
            <p>&copy; @DateTime.Now.Year — <strong>مُنقذك AI</strong> — منظومة ذكية متكاملة لاكتشاف الاحتيال الرقمي والتصيد الإلكتروني.</p>
        </div>
    </footer>

</body>
</html>